{
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ],
  "functions": {
    "app/main.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/v1/screener/cron/run",
      "schedule": "0 */6 * * *"
    }
  ]
}
